	"summary": "Changing controller attitude sets and holds stick deflection so you can relax or reposition your hand.",
	"control_scheme": "latched_attitude",
	"difficulty": "intermediate",
	"betaflight_recommendation": {
		"recommended": ["Angle"],
		"acceptable": ["Horizon"],
		"avoid": ["Acro/Rate", "Acro Trainer"],
		"notes": "Best when the quad self-levels after each latched input change."
	},
	"liftoff_recommendation": {
		"recommended": ["Level"],
		"acceptable": ["Limited Acro"],
		"avoid": ["Acro", "Full Assist"],
		"notes": "Use assisted flight so the held stick values represent a stable attitude request."
	},
	"liftoff_assists": {
		"recommended": [],
		"optional": ["Hold Altitude"],
		"avoid": [],
		"notes": "Altitude assist can make the latched attitude workflow easier to learn."
	},
	"warnings": [
		"Outputs stay held until you counter-adjust or reset the flight origin.",
		"Avoid Acro; latched stick deflection becomes continuous rotation there."
	],
	"usage_tips": [
		"Make short deliberate hand adjustments instead of holding a big tilt.",
		"Release the clutch and recentre your hand whenever the held command feels offset."
	],
