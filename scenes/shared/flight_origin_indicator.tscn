[sub_resource type="Shader" id="1_indicator_shader"]
code = "shader_type spatial;
render_mode unshaded, cull_disabled, blend_mix, depth_draw_never;

uniform vec4 base_color : source_color = vec4(0.25, 0.65, 1.0, 0.18);
uniform vec4 highlight_color : source_color = vec4(1.0, 0.18, 0.18, 0.7);
uniform vec3 highlight_direction = vec3(0.0, 0.0, -1.0);
uniform float highlight_strength : hint_range(0.0, 1.0) = 0.0;

void fragment() {
	vec3 dir = normalize(highlight_direction);
	float lobe = pow(max(dot(normalize(NORMAL), dir), 0.0), 6.0) * highlight_strength;
	vec4 color = base_color + highlight_color * lobe;
	ALBEDO = color.rgb;
	ALPHA = clamp(color.a, 0.0, 1.0);
}
"

[sub_resource type="ShaderMaterial" id="2_indicator_material"]
render_priority = 0
