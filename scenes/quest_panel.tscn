[node name="Tuning" type="VBoxContainer" parent="Panel/Margin/Scroll/VBox"]
layout_mode = 2

[node name="SensitivityLabel" type="Label" parent="Panel/Margin/Scroll/VBox/Tuning"]
layout_mode = 2
