{
	"schema_version": 2,
	"template_id": "bundled.impulse_flick",
	"slug": "impulse_flick",
	"display_name": "Impulse Flick",
	"origin": "bundled",
	"source_template_id": "",
	"summary": "Fast controller flicks step the held output so each impulse nudges the drone into a new attitude request.",
	"control_scheme": "impulse_latched",
	"difficulty": "advanced",
	"betaflight_recommendation": {
		"recommended": ["Angle"],
		"acceptable": ["Horizon"],
		"avoid": ["Acro/Rate", "Acro Trainer"],
		"notes": "Treat the flick as a way to set a new attitude request, not a sustained rate input."
	},
	"liftoff_recommendation": {
		"recommended": ["Level"],
		"acceptable": ["Limited Acro"],
		"avoid": ["Acro", "Full Assist"],
		"notes": "Limited Acro is acceptable for experiments, but pure Acro becomes too easy to over-command."
	},
	"liftoff_assists": {
		"recommended": [],
		"optional": [],
		"avoid": ["Hold Altitude"],
		"notes": "The template already uses stepwise control; extra altitude assist tends to blur the feedback."
	},
	"warnings": [
		"Flick magnitude changes the held output, not just the instant you move.",
		"Over-aggressive wrist snaps can quickly saturate pitch and roll."
	],
	"usage_tips": [
		"Use small repeatable snaps instead of large swings.",
		"Counter-flick to remove held output before landing."
	],
