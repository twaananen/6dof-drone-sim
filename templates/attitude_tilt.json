{
  "template_name": "attitude_tilt",
  "description": "Simple embodied tilt mapping for intuitive angle-style flight.",
  "outputs": {
    "throttle": {
      "bindings": [
        {
          "source": "trigger",
          "mode": "absolute",
          "range_min": 0.0,
          "range_max": 1.0,
          "weight": 1.0,
          "invert": false,
          "smoothing": 0.01,
          "curve": "linear"
        }
      ]
    },
    "yaw": {
      "bindings": [
        {
          "source": "swing_yaw_deg",
          "mode": "absolute",
          "range_min": -70.0,
          "range_max": 70.0,
          "weight": 1.0,
          "invert": true,
          "smoothing": 0.01,
          "curve": "linear"
        }
      ],
      "deadzone": 0.05
    },
    "pitch": {
      "bindings": [
        {
          "source": "swing_pitch_deg",
          "mode": "absolute",
          "range_min": -45.0,
          "range_max": 45.0,
          "weight": 1.0,
          "invert": false,
          "smoothing": 0.01,
          "curve": "expo_soft"
        }
      ],
      "deadzone": 0.05
    },
    "roll": {
      "bindings": [
        {
          "source": "twist_roll_deg",
          "mode": "absolute",
          "range_min": -45.0,
          "range_max": 45.0,
          "weight": 1.0,
          "invert": false,
          "smoothing": 0.01,
          "curve": "expo_soft"
        }
      ],
      "deadzone": 0.05
    },
    "aux_button_1": {
      "bindings": [
        {
          "source": "button_south",
          "mode": "absolute",
          "range_min": 0.0,
          "range_max": 1.0,
          "weight": 1.0,
          "invert": false,
          "smoothing": 0.0,
          "curve": "linear"
        }
      ]
    },
    "aux_button_2": {
      "bindings": [
        {
          "source": "button_east",
          "mode": "absolute",
          "range_min": 0.0,
          "range_max": 1.0,
          "weight": 1.0,
          "invert": false,
          "smoothing": 0.0,
          "curve": "linear"
        }
      ]
    },
    "aux_button_4": {
      "bindings": [
        {
          "source": "button_thumbstick",
          "mode": "absolute",
          "range_min": 0.0,
          "range_max": 1.0,
          "weight": 1.0,
          "invert": false,
          "smoothing": 0.0,
          "curve": "linear"
        }
      ]
    }
  }
}
