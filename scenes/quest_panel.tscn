[gd_scene format=3]

[node name="QuestPanel" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Panel" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Margin" type="MarginContainer" parent="Panel"]
layout_mode = 2
theme_override_constants/margin_left = 18
theme_override_constants/margin_top = 18
theme_override_constants/margin_right = 18
theme_override_constants/margin_bottom = 18

[node name="Scroll" type="ScrollContainer" parent="Panel/Margin"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="VBox" type="VBoxContainer" parent="Panel/Margin/Scroll"]
layout_mode = 2
size_flags_horizontal = 3

[node name="StatusLabel" type="Label" parent="Panel/Margin/Scroll/VBox"]
custom_minimum_size = Vector2(0, 220)
layout_mode = 2
text = "Starting Quest runtime..."
autowrap_mode = 3

[node name="ConnectionLabel" type="Label" parent="Panel/Margin/Scroll/VBox"]
layout_mode = 2
text = "Connection"

[node name="ConnectModeLabel" type="Label" parent="Panel/Margin/Scroll/VBox"]
layout_mode = 2
text = "Connect Mode"

[node name="ConnectModeSelect" type="OptionButton" parent="Panel/Margin/Scroll/VBox"]
layout_mode = 2

[node name="ManualServerHostLabel" type="Label" parent="Panel/Margin/Scroll/VBox"]
layout_mode = 2
text = "Manual Server Host"

[node name="ManualServerHostEdit" type="LineEdit" parent="Panel/Margin/Scroll/VBox"]
layout_mode = 2
placeholder_text = "192.168.1.42"

[node name="ConnectionButtons" type="HBoxContainer" parent="Panel/Margin/Scroll/VBox"]
layout_mode = 2

[node name="ApplyConnectionButton" type="Button" parent="Panel/Margin/Scroll/VBox/ConnectionButtons"]
layout_mode = 2
text = "Apply Connection"

[node name="RetryConnectButton" type="Button" parent="Panel/Margin/Scroll/VBox/ConnectionButtons"]
layout_mode = 2
text = "Retry Connect"

[node name="RecenterPanelButton" type="Button" parent="Panel/Margin/Scroll/VBox/ConnectionButtons"]
layout_mode = 2
text = "Recenter Panel"

[node name="WorkflowPresetLabel" type="Label" parent="Panel/Margin/Scroll/VBox"]
layout_mode = 2
text = "Workflow Preset"

[node name="PresetSelect" type="OptionButton" parent="Panel/Margin/Scroll/VBox"]
layout_mode = 2

[node name="WorkflowModeLabel" type="Label" parent="Panel/Margin/Scroll/VBox"]
layout_mode = 2
text = "Workflow Mode"

[node name="WorkflowModeSelect" type="OptionButton" parent="Panel/Margin/Scroll/VBox"]
layout_mode = 2

[node name="WorkflowDetailsLabel" type="Label" parent="Panel/Margin/Scroll/VBox"]
custom_minimum_size = Vector2(0, 96)
layout_mode = 2
text = "Recommended. Run the controller app on Quest and view the sim on a monitor through passthrough."
autowrap_mode = 3

[node name="ChecklistLabel" type="Label" parent="Panel/Margin/Scroll/VBox"]
layout_mode = 2
text = "Manual Checklist"

[node name="ChecklistBox" type="VBoxContainer" parent="Panel/Margin/Scroll/VBox"]
layout_mode = 2

[node name="StreamClientLabel" type="Label" parent="Panel/Margin/Scroll/VBox"]
